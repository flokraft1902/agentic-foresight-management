# Basis-URL dieser Next.js App (wird für Server Actions benötigt)
REVIEW_CONSOLE_BASE_URL=http://localhost:3000

# Fallback Callback URL zu n8n (wird verwendet wenn kein callbackUrl im Intake-Payload mitgeschickt wird)
